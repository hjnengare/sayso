# Meetup OAuth credentials
# Get these from: https://secure.meetup.com/meetup_api/oauth_consumers/
MEETUP_CLIENT_KEY=your_oauth_consumer_key
MEETUP_MEMBER_ID=your_meetup_member_id
# RSA private key for JWT signing — literal \n or real newlines both work
MEETUP_SIGNING_SECRET=-----BEGIN RSA PRIVATE KEY-----\nyour_private_key_here\n-----END RSA PRIVATE KEY-----

# Supabase (loaded automatically from repo root .env — only set here to override)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# System identity UUIDs (loaded automatically from repo root .env — only set here to override)
# SYSTEM_BUSINESS_ID=00000000-0000-0000-0000-000000000000
# SYSTEM_USER_ID=00000000-0000-0000-0000-000000000000

# Search radius in km around Cape Town city centre (default: 30)
FETCH_RADIUS_KM=60

# Number of events per page — max 200 (default: 200)
PAGE_SIZE=200

# Run an immediate ingest on startup (default: false)
RUN_ON_START=true
